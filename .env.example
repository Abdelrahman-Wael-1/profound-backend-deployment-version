# Environment Variables — Required for Deployment
# Copy this file to .env for local development and fill in the values.
# For Vercel, set these as Environment Variables in the Vercel Dashboard.
# NEVER commit the actual .env file to version control.

# ── PostgreSQL (Neon) ──────────────────────────────────────────────────────────
DB_USER=your_neon_db_user
DB_PASSWORD=your_neon_db_password
DB_HOST=your_neon_db_host.neon.tech
DB_PORT=5432
DB_NAME=your_db_name

# ── Groq AI API Keys ───────────────────────────────────────────────────────────
GROQ_API_KEY_ANALYSIS=your_groq_api_key
GROQ_API_KEY_EXAM=your_groq_api_key
GROQ_API_KEY_LECTURE=your_groq_api_key
GROQ_API_KEY_GRADING=your_groq_api_key
